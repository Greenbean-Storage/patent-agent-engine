{
  "title": "InventionObjectModel",
  "description": "IOM (Invention Object Model). 출원서를 만들기 위한 객체 모델 — DOM이 'document'를 표현하듯 IOM은 '발명(invention)'이라는 entity를 표현. WIPO ST.96 PatentDocument를 만들기 위한 source-of-truth. 루트는 시스템 헤더(meta)와 출원서 본문 4섹션(bibliographic·specification·claims·abstract)으로 구성. 도면·세션 상태·AI 작업 결과는 별도 파일(drawings/, contexts/)에서 관리.",
  "type": "object",
  "required": [
    "meta",
    "bibliographic",
    "claims"
  ],
  "properties": {
    "meta": {
      "type": "object",
      "description": "시스템 헤더. IOM 인스턴스의 정체성·버전·소유자 정보. 출원서 본문과 분리.",
      "required": [
        "model_id",
        "version",
        "user_id",
        "work_id"
      ],
      "properties": {
        "model_id": {
          "type": "string",
          "format": "uuid",
          "description": "고유 모델 ID"
        },
        "version": {
          "type": "string",
          "pattern": "^\\d+\\.\\d+\\.\\d+$",
          "description": "모델 인스턴스 버전 (semver)"
        },
        "created_at": {
          "type": "string",
          "format": "date-time"
        },
        "updated_at": {
          "type": "string",
          "format": "date-time"
        },
        "user_id": {
          "type": "string",
          "description": "사용자 식별자"
        },
        "work_id": {
          "type": "string",
          "description": "발명 아이템 식별자 (사용자당 여러 발명 가능)"
        }
      }
    },
    "bibliographic": {
      "description": "서지사항. 출원서 표지 및 기본 정보.",
      "type": "object",
      "required": [
        "title"
      ],
      "properties": {
        "title": {
          "type": "object",
          "description": "발명의 명칭 (다국어 변형). PCT 출원시 ko/en 둘 다 필요.",
          "required": [
            "ko"
          ],
          "properties": {
            "ko": {
              "type": "string",
              "description": "발명의 명칭 (한국어)"
            },
            "en": {
              "type": [
                "string",
                "null"
              ],
              "description": "발명의 명칭 (영어, PCT 출원 시 필요)"
            }
          }
        },
        "inventors": {
          "type": "array",
          "description": "발명자 목록 (복수 발명자 가능). 출원인과 법적으로 별개.",
          "items": {
            "type": "object",
            "required": [
              "name"
            ],
            "properties": {
              "name": {
                "type": "string"
              },
              "nationality": {
                "type": [
                  "string",
                  "null"
                ]
              },
              "address": {
                "type": [
                  "string",
                  "null"
                ]
              },
              "share": {
                "type": [
                  "number",
                  "null"
                ],
                "description": "발명 기여도 (%)"
              }
            }
          }
        },
        "applicant": {
          "type": "object",
          "description": "출원인 (발명자와 다를 수 있음)",
          "properties": {
            "name": {
              "type": "string"
            },
            "type": {
              "type": "string",
              "enum": [
                "individual",
                "corporation",
                "university",
                "government"
              ]
            },
            "address": {
              "type": [
                "string",
                "null"
              ]
            },
            "nationality": {
              "type": [
                "string",
                "null"
              ]
            },
            "registration_number": {
              "type": [
                "string",
                "null"
              ],
              "description": "사업자등록번호 또는 법인등록번호"
            }
          }
        },
        "classification": {
          "type": "object",
          "description": "특허분류 코드 (IPC·CPC). 등록시 자동 부여되며 조기 지정 가능.",
          "properties": {
            "ipc": {
              "type": "array",
              "description": "IPC 국제특허분류 코드. 예: B65D 1/00",
              "items": {
                "type": "string"
              }
            },
            "cpc": {
              "type": "array",
              "description": "CPC 협력특허분류 코드",
              "items": {
                "type": "string"
              }
            }
          }
        },
        "priority": {
          "type": "object",
          "description": "우선권 주장 (국내·국제). 우선권 주장이 없으면 둘 다 null.",
          "properties": {
            "domestic": {
              "type": [
                "object",
                "null"
              ],
              "description": "국내우선권 주장",
              "properties": {
                "application_number": {
                  "type": "string"
                },
                "filing_date": {
                  "type": "string",
                  "format": "date"
                }
              }
            },
            "international": {
              "type": [
                "object",
                "null"
              ],
              "description": "파리협약 우선권 주장",
              "properties": {
                "country": {
                  "type": "string"
                },
                "application_number": {
                  "type": "string"
                },
                "filing_date": {
                  "type": "string",
                  "format": "date"
                }
              }
            }
          }
        },
        "filing_type": {
          "type": "string",
          "enum": [
            "domestic",
            "pct"
          ],
          "default": "domestic",
          "description": "국내 출원 또는 PCT 국제 출원"
        }
      }
    },
    "specification": {
      "description": "명세서. 한국 특허법 시행규칙 §21 기준 법정 5섹션. 각 섹션이 비어있을 수 있으며 AI 분석 결과로 점진적으로 채워진다.",
      "type": "object",
      "properties": {
        "technical_field": {
          "type": [
            "string",
            "null"
          ],
          "description": "기술분야. '본 발명은 ... 에 관한 것이다.' 형식."
        },
        "background_art": {
          "type": [
            "object",
            "null"
          ],
          "description": "발명의 배경이 되는 기술",
          "properties": {
            "description": {
              "type": "string",
              "description": "기존 기술 상황 설명"
            },
            "problems": {
              "type": "array",
              "items": {
                "type": "string"
              },
              "description": "기존 기술의 문제점"
            },
            "prior_art_refs": {
              "type": "array",
              "description": "인용 선행기술 목록",
              "items": {
                "type": "object",
                "properties": {
                  "type": {
                    "type": "string",
                    "enum": [
                      "patent",
                      "literature"
                    ]
                  },
                  "number": {
                    "type": "string",
                    "description": "특허번호 또는 문헌번호"
                  },
                  "title": {
                    "type": [
                      "string",
                      "null"
                    ]
                  },
                  "country": {
                    "type": [
                      "string",
                      "null"
                    ]
                  }
                }
              }
            }
          }
        },
        "disclosure": {
          "type": [
            "object",
            "null"
          ],
          "description": "발명의 내용. 시행규칙 §21조에 따라 과제·해결수단·효과로 분리 작성 의무.",
          "properties": {
            "problem_to_solve": {
              "type": "string",
              "description": "해결하려는 과제"
            },
            "solution": {
              "type": "string",
              "description": "과제의 해결 수단"
            },
            "effect": {
              "type": "string",
              "description": "발명의 효과"
            }
          }
        },
        "brief_description_of_drawings": {
          "type": "array",
          "description": "도면의 간단한 설명. drawings/manifest.drawing.yaml의 도면 목록과 1:1 대응. 출원서 명세서 섹션에 들어가는 텍스트만 여기에 보관.",
          "items": {
            "type": "object",
            "required": [
              "figure_label",
              "description"
            ],
            "properties": {
              "figure_label": {
                "type": "string",
                "description": "예: 도 1"
              },
              "description": {
                "type": "string"
              }
            }
          }
        },
        "detailed_description": {
          "type": [
            "string",
            "null"
          ],
          "description": "발명을 실시하기 위한 구체적인 내용. 실시예를 포함하며 특허 명세서에서 가장 긴 섹션."
        },
        "embodiments": {
          "type": "array",
          "description": "실시예 목록",
          "items": {
            "type": "object",
            "required": [
              "id",
              "title",
              "description"
            ],
            "properties": {
              "id": {
                "type": "integer"
              },
              "title": {
                "type": "string",
                "description": "예: 제1 실시예"
              },
              "description": {
                "type": "string"
              },
              "figures": {
                "type": "array",
                "items": {
                  "type": "string"
                },
                "description": "참조 도면 번호 목록"
              },
              "variations": {
                "type": "array",
                "items": {
                  "type": "string"
                },
                "description": "변형 실시예"
              }
            }
          }
        },
        "industrial_applicability": {
          "type": [
            "string",
            "null"
          ],
          "description": "산업상 이용가능성 (선택적 섹션, PCT 출원시 권장)"
        }
      }
    },
    "claims": {
      "type": "array",
      "description": "청구항 목록. 청구항 1은 반드시 독립항. 독립항은 발명의 핵심 권리 범위를 정의한다.",
      "minItems": 1,
      "items": {
        "type": "object",
        "required": [
          "number",
          "type",
          "text"
        ],
        "properties": {
          "number": {
            "type": "integer",
            "minimum": 1,
            "description": "청구항 번호"
          },
          "type": {
            "type": "string",
            "enum": [
              "independent",
              "dependent"
            ],
            "description": "독립항 또는 종속항"
          },
          "dependent_on": {
            "type": [
              "integer",
              "null"
            ],
            "description": "종속항인 경우 인용하는 청구항 번호"
          },
          "text": {
            "type": "string",
            "description": "청구항 원문. 법적 효력을 갖는 텍스트."
          },
          "_analysis": {
            "type": "object",
            "description": "내부 분석 메타. 출원서 본문에 포함되지 않음. claim 객체 내에서 법적 본문(number/type/text)과 시각적으로 격리하기 위해 underscore prefix.",
            "properties": {
              "elements": {
                "type": "array",
                "description": "청구항 구성요소 분해",
                "items": {
                  "type": "object",
                  "properties": {
                    "id": {
                      "type": "string"
                    },
                    "name": {
                      "type": "string"
                    },
                    "description": {
                      "type": "string"
                    },
                    "is_novel": {
                      "type": "boolean"
                    }
                  }
                }
              },
              "scope_notes": {
                "type": [
                  "string",
                  "null"
                ],
                "description": "청구항 권리범위에 대한 내부 메모"
              },
              "status": {
                "type": "string",
                "enum": [
                  "draft",
                  "reviewed",
                  "final"
                ],
                "default": "draft"
              }
            }
          }
        }
      }
    },
    "abstract": {
      "description": "요약서. 발명의 핵심을 400자 이내로 요약.",
      "type": "object",
      "properties": {
        "text": {
          "type": [
            "string",
            "null"
          ],
          "description": "요약 텍스트. 400자 이내 권장.",
          "maxLength": 500
        },
        "representative_figure": {
          "type": [
            "string",
            "null"
          ],
          "description": "대표도 번호. 예: 도 1 — drawings/manifest.drawing.yaml의 figure_label과 매칭."
        }
      }
    }
  }
}
