{
  "type": "object",
  "properties": {
    "invention_summary": {
      "type": "string",
      "description": "발명 요약 한 문장 — '<주체>가 <수단>으로 <효과>를 달성하는 <대상>'"
    },
    "technical_elements": {
      "type": "array",
