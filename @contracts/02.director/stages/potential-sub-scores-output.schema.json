{
  "$schema": "https://json-schema.org/draft/2020-12/schema",
  "type": "object",
  "additionalProperties": false,
  "description": "P02.R00.CONCEPT_MATURITY step 4 (score_potential) LLM output. 2 sub-score (differentiation / effect) + rationale.",
  "required": ["differentiation", "effect", "rationale"],
  "properties": {
    "differentiation": { "type": "number", "minimum": 0, "maximum": 1, "multipleOf": 0.01 },
    "effect":          { "type": "number", "minimum": 0, "maximum": 1, "multipleOf": 0.01 },
    "rationale":       { "type": "string", "minLength": 20 }
  }
}
