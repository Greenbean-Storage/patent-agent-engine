{
  "$schema": "https://json-schema.org/draft/2020-12/schema",
  "title": "UpdateRoadmapOutput",
  "description": "P02.R00.CONCEPT_MATURITY step 6 (update_roadmap) Agent step 의 LLM 응답. top-level array — UserRoadmap 와 동일 형태 (8 필드 item).",
  "type": "array",
  "items": {
    "type": "object",
    "additionalProperties": false,
    "required": ["id", "title", "description", "status", "priority", "input_type", "options", "answer"],
    "properties": {
      "id":          { "type": "string" },
      "title":       { "type": "string", "minLength": 1 },
      "description": { "type": "string" },
      "status":      { "type": "string", "enum": ["pending", "satisfied", "skipped"] },
      "priority":    { "type": "integer", "minimum": 1, "maximum": 5 },
      "input_type":  { "type": "string", "enum": ["chat", "selection", "checkbox", "keyword", "none"] },
      "options":     { "type": ["array", "null"], "items": { "type": "string" } },
      "answer": {
        "oneOf": [
          { "type": "null" },
          {
            "type": "object",
            "additionalProperties": false,
            "required": ["value", "answered_at"],
            "properties": {
              "value": {
                "oneOf": [
                  { "type": "string" },
                  { "type": "array", "items": { "type": "string" } }
                ]
              },
              "answered_at": { "type": "string", "format": "date-time" }
            }
          }
        ]
      }
    }
  }
}
