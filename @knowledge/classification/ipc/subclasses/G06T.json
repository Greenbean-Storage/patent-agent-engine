        {
          "code": "G06T 3/4046",
          "title": {
            "ko": null,
            "en": "using neural networks"
          }
        },
        {
          "code": "G06T 3/4053",
          "title": {
            "ko": null,
            "en": "based on super-resolution, i.e. the output image resolution being higher than the sensor resolution"
          }
        },
        {
          "code": "G06T 3/4061",
          "title": {
            "ko": null,
            "en": "by injecting details from different spectral ranges"
          }
        },
        {
          "code": "G06T 3/4069",
          "title": {
            "ko": null,
            "en": "by subpixel displacements"
          }
        },
        {
          "code": "G06T 3/4076",
          "title": {
            "ko": null,
            "en": "using the original low-resolution images to iteratively correct the high-resolution images"
          }
        },
        {
          "code": "G06T 3/4084",
          "title": {
            "ko": null,
            "en": "in the transform domain, e.g. fast Fourier transform [FFT] domain scaling"
          }
        },
        {
          "code": "G06T 3/4092",
          "title": {
            "ko": null,
            "en": "Image resolution transcoding, e.g. by using client-server architectures"
          }
        },
        {
          "code": "G06T 3/60",
          "title": {
            "ko": null,
            "en": "Rotation of whole images or parts thereof"
          }
        },
        {
          "code": "G06T 3/602",
          "title": {
            "ko": null,
            "en": "by block rotation, e.g. by recursive reversal or rotation"
          }
        },
        {
          "code": "G06T 3/604",
          "title": {
            "ko": null,
            "en": "using coordinate rotation digital computer [CORDIC] devices"
          }
        },
        {
          "code": "G06T 3/606",
          "title": {
            "ko": null,
            "en": "by memory addressing or mapping"
          }
        },
        {
          "code": "G06T 3/608",
          "title": {
            "ko": null,
            "en": "by skew deformation, e.g. two-pass or three-pass rotation"
          }
        }
      ]
    },
