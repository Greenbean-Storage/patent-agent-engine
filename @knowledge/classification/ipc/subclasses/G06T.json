        },
        {
          "code": "G06T 1/40",
          "title": {
            "ko": null,
            "en": "Neural networks"
          }
        },
        {
          "code": "G06T 1/60",
          "title": {
            "ko": null,
            "en": "Memory management"
          }
        }
      ]
    },
    {
      "code": "G06T 3/00",
      "title": {
        "ko": "이미지 평면의 기하학적 이미지 변환",
        "en": "Geometric image transformations in the plane of the image"
      },
      "subgroups": [
        {
          "code": "G06T 3/02",
          "title": {
            "ko": "아핀 변환(이미지 등록용 G06T3/147, 이미지 모자이크용 G06T3/4038)",
            "en": "Affine transformations (for image registration G06T0003147000;for image mosaicing G06T0003403800)"
          }
        },
        {
          "code": "G06T 3/04",
          "title": {
            "ko": "컨텍스트 보존 변환, 예. 중요도 맵 사용(파노스피어에서 원통형 이미지 변환 G06T3/12)",
            "en": "Context-preserving transformations, e.g. by using an importance map (panospheric to cylindrical image transformations G06T0003120000)"
          }
        },
        {
          "code": "G06T 3/047",
          "title": {
            "ko": null,
            "en": "Fisheye or wide-angle transformations"
          }
        },
        {
          "code": "G06T 3/053",
          "title": {
            "ko": "상황에 맞는 세부 프레젠테이션(어안 또는 광각 변환 G06T3/047)",
            "en": "Detail-in-context presentations (fisheye or wide-angle transformations G06T0003047000)"
          }
        },
        {
          "code": "G06T 3/06",
          "title": {
            "ko": null,
            "en": "Topological mapping of higher dimensional structures onto lower dimensional surfaces"
          }
        },
        {
          "code": "G06T 3/067",
          "title": {
            "ko": null,
            "en": "Reshaping or unfolding three-dimensional [3D] tree structures onto two-dimensional [2D] planes"
          }
        },
        {
          "code": "G06T 3/073",
          "title": {
            "ko": null,
            "en": "Transforming surfaces of revolution to planar images, e.g. cylindrical surfaces to planar images"
          }
        },
        {
          "code": "G06T 3/08",
          "title": {
            "ko": null,
            "en": "Projecting images onto non-planar surfaces, e.g. geodetic screens"
          }
        },
        {
          "code": "G06T 3/10",
          "title": {
            "ko": null,
            "en": "Selection of transformation methods according to the characteristics of the input images"
          }
        },
        {
          "code": "G06T 3/12",
          "title": {
            "ko": null,
            "en": "Panospheric to cylindrical image transformations"
          }
        },
        {
          "code": "G06T 3/14",
          "title": {
            "ko": null,
            "en": "Transformations for image registration, e.g. adjusting or mapping for alignment of images"
          }
        },
        {
          "code": "G06T 3/147",
          "title": {
            "ko": null,
            "en": "using affine transformations"
          }
        },
        {
          "code": "G06T 3/153",
          "title": {
            "ko": null,
            "en": "using elastic snapping"
          }
        },
        {
          "code": "G06T 3/16",
          "title": {
            "ko": null,
            "en": "Spatio-temporal transformations, e.g. video cubism"
          }
        },
        {
          "code": "G06T 3/18",
          "title": {
            "ko": null,
            "en": "Image warping, e.g. rearranging pixels individually"
          }
        },
        {
          "code": "G06T 3/20",
          "title": {
            "ko": null,
            "en": "Linear translation of whole images or parts thereof, e.g. panning"
          }
        },
        {
          "code": "G06T 3/40",
          "title": {
            "ko": "전체 이미지 또는 그 일부의 크기 조정, 예. 확장 또는 축소",
            "en": "Scaling of whole images or parts thereof, e.g. expanding or contracting"
          }
        },
        {
          "code": "G06T 3/4007",
          "title": {
            "ko": "보간법 기반, 예. 이중선형 보간(이미지 디모자이크 G06T3/4015, 에지 중심 또는 에지 기반 스케일링 G06T3/403)",
            "en": "based on interpolation, e.g. bilinear interpolation (image demosaicing G06T0003401500;edge-driven or edge-based scaling G06T0003403000)"
          }
        },
        {
          "code": "G06T 3/4015",
          "title": {
            "ko": null,
            "en": "Image demosaicing, e.g. colour filter arrays [CFA] or Bayer patterns"
          }
        },
        {
          "code": "G06T 3/4023",
          "title": {
            "ko": null,
            "en": "based on decimating pixels or lines of pixels; based on inserting pixels or lines of pixels"
          }
        },
        {
          "code": "G06T 3/403",
          "title": {
            "ko": null,
            "en": "Edge-driven scaling; Edge-based scaling"
          }
        },
        {
          "code": "G06T 3/4038",
          "title": {
            "ko": null,
            "en": "Image mosaicing, e.g. composing plane images from plane sub-images"
          }
