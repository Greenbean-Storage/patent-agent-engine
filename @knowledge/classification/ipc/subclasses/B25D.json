{
  "subclass": "B25D",
  "title": {
    "ko": "충격 공구",
    "en": "PERCUSSIVE TOOLS"
  },
  "definition": {
    "ko": "작동방법에 의하여 분류되는 공구 B25D9/00 ~ B25D16/00 해머, 끌, 펀치 또는 픽 B25D1/00 ~ B25D7/00 세부 또는 부속품 B25D17/00",
    "en": null
  },
  "groups": [
    {
      "code": "B25D 1/00",
      "title": {
        "ko": "손해머; 특수 모양 또는 특수재질의 해머 머리",
        "en": "Hand hammers; Hammer heads of special shape or materials"
      },
      "subgroups": [
        {
          "code": "B25D 1/02",
          "title": {
            "ko": "해머 머리의 타격부분을 형성하는 삽입물 또는 부착물(B25D 1/08 ~ B25D 1/14가 우선)",
            "en": "Inserts or attachments forming the striking part of hammer heads (B25D0001080000-B25D0001140000 take precedence)"
          }
        },
        {
          "code": "B25D 1/04",
          "title": {
            "ko": null,
            "en": "with provision for withdrawing or holding nails or spikes"
          }
        },
        {
