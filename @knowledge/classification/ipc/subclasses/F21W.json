        {
          "code": "F21W 102/13",
          "title": {
            "ko": null,
            "en": "for high-beam region or low-beam region"
          }
        },
        {
          "code": "F21W 102/135",
          "title": {
            "ko": null,
            "en": "the light having cut-off lines, i.e. clear borderlines between emitted regions and dark regions"
          }
        },
        {
          "code": "F21W 102/14",
          "title": {
            "ko": null,
            "en": "having vertical cut-off lines; specially adapted for adaptive high beams, i.e. the beam is broader but avoids glaring other road users"
          }
        },
        {
          "code": "F21W 102/145",
          "title": {
