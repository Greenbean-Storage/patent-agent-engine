{
  "subclass": "A46B",
  "title": {
    "ko": "브러시",
    "en": "BRUSHES"
  },
  "definition": {
    "ko": "브러시(BRUSH) A46B1/00, A46B11/00, A46B13/00, A46B15/00 브러시의 세부 A46B1/00 ~ A46B9/00 부속품 A46B17/00",
    "en": null
  },
  "groups": [
    {
      "code": "A46B 1/00",
      "title": {
        "ko": null,
        "en": "Brush bodies and bristles moulded as a unit"
      },
      "subgroups": []
    },
    {
      "code": "A46B 3/00",
      "title": {
        "ko": "브러시 몸체 또는 지지체에 털을 고정 또는 결합시키는 방법에 특징이 있는 브러시",
        "en": "Brushes characterised by the way in which the bristles are fixed or joined in or on the brush body or carrier"
      },
      "subgroups": [
        {
          "code": "A46B 3/02",
          "title": {
            "ko": null,
            "en": "by pitch, resin, cement, or other adhesives"
          }
        },
        {
          "code": "A46B 3/04",
          "title": {
            "ko": "성형할 수 있는 재료, 예. 금속, 섬유소 유도물, 합성수지에 의한 것(A46B 1/00이 우선)",
            "en": "by mouldable materials, e.g. metals, cellulose derivatives, plastics (A46B0001000000 takes precedence)"
          }
        },
        {
          "code": "A46B 3/06",
          "title": {
            "ko": null,
            "en": "by welding together bristles made of metal wires or plastic materials"
          }
        },
        {
          "code": "A46B 3/08",
          "title": {
            "ko": null,
            "en": "by clamping"
          }
        },
        {
          "code": "A46B 3/10",
          "title": {
            "ko": null,
            "en": "into rings or the like"
          }
        },
        {
          "code": "A46B 3/12",
          "title": {
            "ko": null,
            "en": "specially adapted for paint-brushes"
          }
        },
        {
          "code": "A46B 3/14",
          "title": {
            "ko": null,
            "en": "specially adapted for street-cleaning or rail-cleaning brooms"
          }
        },
        {
          "code": "A46B 3/16",
          "title": {
            "ko": null,
            "en": "by wires or other anchoring means, specially for U-shaped bristle tufts"
          }
        },
        {
          "code": "A46B 3/18",
          "title": {
            "ko": null,
            "en": "the bristles being fixed on or between belts or wires"
          }
        },
        {
          "code": "A46B 3/20",
          "title": {
            "ko": null,
            "en": "the bristles being fixed or joined in rubber bodies, e.g. in soft rubber"
          }
        },
        {
          "code": "A46B 3/22",
          "title": {
            "ko": null,
            "en": "rubber bristles being fixed in or on brush bodies"
          }
        }
      ]
    },
    {
      "code": "A46B 5/00",
      "title": {
        "ko": null,
        "en": "Brush bodies; Handles integral with brushware"
      },
      "subgroups": [
        {
          "code": "A46B 5/02",
          "title": {
            "ko": null,
            "en": "specially shaped for holding by the hand"
          }
        },
        {
          "code": "A46B 5/04",
          "title": {
            "ko": null,
            "en": "shaped as gloves or finger-stalls"
          }
        },
        {
          "code": "A46B 5/06",
          "title": {
            "ko": null,
            "en": "in the form of tapes, chains, flexible shafts, springs, or the like"
          }
        }
      ]
    },
    {
      "code": "A46B 7/00",
      "title": {
        "ko": null,
        "en": "Bristle carriers arranged in the brush body"
      },
      "subgroups": [
        {
          "code": "A46B 7/02",
          "title": {
            "ko": null,
            "en": "in an expanding or articulating manner"
          }
        },
        {
          "code": "A46B 7/04",
          "title": {
            "ko": null,
            "en": "interchangeably"
          }
        },
        {
          "code": "A46B 7/06",
          "title": {
            "ko": null,
            "en": "movably during use"
          }
        },
        {
          "code": "A46B 7/08",
          "title": {
            "ko": null,
            "en": "as a rotating disc"
          }
        },
        {
          "code": "A46B 7/10",
          "title": {
            "ko": null,
            "en": "as a rotating cylinder"
          }
        }
      ]
    },
    {
      "code": "A46B 9/00",
      "title": {
        "ko": null,
        "en": "Arrangements of the bristles in the brush body"
      },
      "subgroups": [
        {
          "code": "A46B 9/02",
          "title": {
            "ko": null,
            "en": "Position or arrangement of bristles in relation to surface of the brush body, e.g. inclined, in rows, in groups"
          }
        },
        {
          "code": "A46B 9/04",
          "title": {
            "ko": null,
            "en": "for toothbrushes"
          }
        },
        {
          "code": "A46B 9/06",
          "title": {
            "ko": null,
            "en": "Arrangement of mixed bristles or tufts of bristles, e.g. wire, fibre, rubber"
          }
        },
        {
          "code": "A46B 9/08",
          "title": {
            "ko": null,
            "en": "Supports or guides for bristles"
          }
        },
        {
          "code": "A46B 9/10",
          "title": {
            "ko": null,
            "en": "Adjustable supports"
          }
        },
        {
          "code": "A46B 9/12",
          "title": {
            "ko": null,
            "en": "Non-adjustable supports"
          }
        }
      ]
    },
    {
      "code": "A46B 11/00",
      "title": {
        "ko": "물질을 공급하는 저장소 또는 기타 수단이 구비된 브러시, 예. 염료, 페이스트, 물 (물질 공급수단을 위한 저장소 또는 기타 수단이 구비된 구동체를 지닌 브러시 A46B13/04)",
        "en": "Brushes with reservoir or other means for applying substances, e.g. paints, pastes or water  (brushes with power-driven brush bodies with reservoir or other means for supplying substances A46B0013040000)"
      },
      "subgroups": [
        {
          "code": "A46B 11/02",
          "title": {
            "ko": null,
            "en": "with substance discharged from reservoir by pressure"
          }
        },
        {
          "code": "A46B 11/04",
          "title": {
            "ko": null,
            "en": "with substance discharged from reservoir otherwise than by pressure"
          }
        },
        {
          "code": "A46B 11/06",
          "title": {
            "ko": null,
            "en": "connected to supply pipe"
          }
        },
        {
          "code": "A46B 11/08",
          "title": {
            "ko": null,
            "en": "with heating means"
          }
        }
      ]
    },
    {
      "code": "A46B 13/00",
      "title": {
        "ko": "구동체를 포함하는 브러시 (전동 브러시 A61C17/22)",
        "en": "Brushes with driven brush bodies  (power-driven toothbrushes A61C0017220000)"
      },
      "subgroups": [
        {
          "code": "A46B 13/02",
          "title": {
            "ko": null,
            "en": "power-driven"
          }
        },
        {
          "code": "A46B 13/04",
          "title": {
            "ko": null,
            "en": "with reservoir or other means for supplying substances"
          }
        },
        {
          "code": "A46B 13/06",
          "title": {
            "ko": null,
            "en": "with brush driven by the supplied medium"
          }
        },
        {
          "code": "A46B 13/08",
          "title": {
            "ko": null,
            "en": "hand-driven"
          }
        }
      ]
    },
    {
      "code": "A46B 15/00",
      "title": {
        "ko": null,
        "en": "Other brushes; Brushes with additional arrangements"
      },
      "subgroups": []
    },
    {
      "code": "A46B 17/00",
      "title": {
        "ko": null,
        "en": "Accessories for brushes"
      },
      "subgroups": [
        {
          "code": "A46B 17/02",
          "title": {
            "ko": null,
            "en": "Devices for holding brushes in use"
          }
        },
        {
          "code": "A46B 17/04",
          "title": {
            "ko": null,
            "en": "Protective covers for the bristles"
          }
        },
        {
          "code": "A46B 17/06",
          "title": {
            "ko": null,
            "en": "Devices for cleaning brushes after use"
          }
        },
        {
          "code": "A46B 17/08",
          "title": {
            "ko": null,
            "en": "Other accessories, e.g. scrapers, rubber buffers for preventing damage to furniture"
          }
        }
      ]
    }
  ]
}
