{
  "subclass": "A23K",
  "title": {
    "ko": "동물을 위해 특히 적합한 먹이; 그것의 생산을 위해 특히 적합한 방법",
    "en": "FEEDING-STUFFS SPECIALLY ADAPTED FOR ANIMALS; METHODS SPECIALLY ADAPTED FOR PRODUCTION THEREOF"
  },
  "groups": [
    {
      "code": "A23K 10/00",
      "title": {
        "ko": "사료",
        "en": "Animal feeding-stuffs"
      },
      "subgroups": [
        {
          "code": "A23K 10/10",
          "title": {
            "ko": "미생물학적 또는 생화학적 공정을 통해서 얻어진 것 (청예 사료(green fodder)의 사일로 저장법을 위해서 화학물 또는 미생물을 사용하는 것 A23K30/15)",
            "en": "obtained by microbiological or biochemical processes (using chemicals or microorganisms for ensilaging of green fodder A23K0030150000)"
          }
        },
        {
          "code": "A23K 10/12",
          "title": {
            "ko": null,
            "en": "by fermentation of natural products, e.g. of vegetable material, animal waste material or biomass"
          }
        },
        {
          "code": "A23K 10/14",
          "title": {
            "ko": null,
            "en": "Pretreatment of feeding-stuffs with enzymes"
          }
        },
        {
          "code": "A23K 10/16",
          "title": {
            "ko": "사료 조성물에 대한 미생물 또는 그 추출물, 예. 단세포 단백질의 추가 (A23K10/12가 우선)",
            "en": "Addition of microorganisms or extracts thereof, e.g. single-cell proteins, to feeding-stuff compositions (A23K0010120000 takes precedence)"
          }
        },
        {
          "code": "A23K 10/18",
          "title": {
            "ko": null,
            "en": "of live microorganisms"
          }
        },
        {
          "code": "A23K 10/20",
          "title": {
            "ko": "동물적 기원의 물질로부터의 것 (미생물학적 또는 생화학적 공정에 의해 얻어진 것 A23K10/10)",
            "en": "from material of animal origin (obtained by microbiological or biochemical processes A23K0010100000)"
          }
        },
        {
          "code": "A23K 10/22",
          "title": {
            "ko": null,
            "en": "from fish"
          }
        },
        {
          "code": "A23K 10/24",
          "title": {
            "ko": null,
            "en": "from blood"
          }
        },
        {
          "code": "A23K 10/26",
          "title": {
            "ko": "폐기물질로부터의 것, 예. 깃털, 뼈 또는 가죽 (A23K 10/24를 우선함 )",
            "en": "from waste material, e.g. feathers, bones or skin (A23K0010240000 takes precedence)"
          }
        },
        {
          "code": "A23K 10/28",
          "title": {
            "ko": null,
            "en": "from waste dairy products"
          }
        },
        {
          "code": "A23K 10/30",
          "title": {
            "ko": "식물 기원의 물질로부터의 것, 예. 뿌리, 씨앗 또는 건초; 균류 기원의 물질로부터의 것, 예. 버섯류 (미생물학적 또는 생화학적 공정에 의해 얻어진 것, 예. 효모 또는 효소를 사용하는 것, A23K 10/10 )",
            "en": "from material of plant origin, e.g. roots, seeds or hay; from material of fungal origin, e.g. mushrooms (obtained by microbiological or biochemical processes, e.g. using yeasts or enzymes, A23K0010100000)"
          }
        },
        {
          "code": "A23K 10/32",
          "title": {
            "ko": null,
            "en": "from hydrolysates of wood or straw"
          }
        },
        {
          "code": "A23K 10/33",
          "title": {
            "ko": null,
            "en": "from molasses"
          }
        },
        {
          "code": "A23K 10/35",
          "title": {
            "ko": null,
            "en": "from potatoes"
          }
        },
        {
          "code": "A23K 10/37",
          "title": {
            "ko": "폐기물질로부터의 것 (목재 또는 짚의 가수분해물로부터의 것 A23K10/32 ;당밀로부터의 것 A23K10/33 )",
            "en": "from waste material (from hydrolysates of wood or straw A23K0010320000;from molasses A23K0010330000)"
          }
