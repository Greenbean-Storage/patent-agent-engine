  "groups": [
    {
      "code": "H04K 1/00",
      "title": {
        "ko": null,
        "en": "Secret communication"
      },
      "subgroups": [
        {
          "code": "H04K 1/003",
          "title": {
            "ko": null,
            "en": "{by varying carrier frequency at or within predetermined or random intervals (H04K1/04 takes precedence)}"
          }
        },
        {
          "code": "H04K 1/006",
          "title": {
            "ko": null,
            "en": "{by varying or inverting the phase, at periodic or random intervals}"
          }
        },
        {
          "code": "H04K 1/02",
          "title": {
            "ko": null,
            "en": "by adding a second signal to make the desired signal unintelligible"
          }
        },
        {
          "code": "H04K 1/04",
          "title": {
            "ko": null,
            "en": "by frequency scrambling, i.e. by transposing or inverting parts of the frequency band or by inverting the whole band"
          }
        },
        {
          "code": "H04K 1/06",
          "title": {
            "ko": null,
            "en": "by transmitting the information or elements thereof at unnatural speeds or in jumbled order or backwards"
          }
        },
        {
          "code": "H04K 1/08",
          "title": {
            "ko": null,
            "en": "by varying the polarisation of transmitted waves"
          }
        },
        {
          "code": "H04K 1/10",
          "title": {
            "ko": null,
            "en": "by using two signals transmitted simultaneously or successively"
          }
        }
      ]
    },
