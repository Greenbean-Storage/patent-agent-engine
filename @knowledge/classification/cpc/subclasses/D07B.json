    },
    {
      "code": "D07B 3/00",
      "title": {
        "ko": null,
        "en": "General-purpose machines or apparatus for producing twisted ropes or cables from component strands of the same or different material"
      },
      "subgroups": [
        {
          "code": "D07B 3/005",
          "title": {
            "ko": null,
            "en": "{with alternating twist directions}"
          }
        },
        {
          "code": "D07B 3/02",
          "title": {
            "ko": null,
            "en": "in which the supply reels rotate about the axis of the rope or cable {or in which a guide member rotates about the axis of the rope or cable to guide the component strands away from the supply reels in fixed position}"
