{
  "subclass": "D07B",
  "title": {
    "ko": null,
    "en": "ROPES OR CABLES IN GENERAL (joining ropes or cables to one another or to other objects B65H69/00, F16G11/00; {mountaineering ropes A63B29/02}; mechanical finishing or dressing of ropes D02J; {braiding D04C}; decorative ropes or cords D04D; suspension cables for bridges E01D19/16; specially adapted for driving, or for being driven by, pulleys or other gearing elements F16G9/00; electric cables or joints insofar as electrical aspects are essential H01B, H01R)"
  },
  "groups": [
    {
      "code": "D07B 1/00",
      "title": {
        "ko": null,
        "en": "Constructional features of ropes or cables"
      },
      "subgroups": [
        {
          "code": "D07B 1/005",
          "title": {
            "ko": null,
            "en": "{Composite ropes, i.e. ropes built-up from fibrous or filamentary material and metal wires}"
          }
        },
        {
          "code": "D07B 1/02",
          "title": {
            "ko": null,
            "en": "Ropes built-up from fibrous or filamentary material, e.g. of vegetable origin, of animal origin, regenerated cellulose, plastics"
          }
        },
        {
          "code": "D07B 1/06",
          "title": {
            "ko": null,
            "en": "Ropes or cables built-up from metal wires, e.g. of section wires around a hemp core"
          }
        },
        {
          "code": "D07B 1/12",
          "title": {
            "ko": null,
            "en": "Ropes or cables with a hollow core"
