        },
        {
          "code": "D07B 3/08",
          "title": {
            "ko": null,
            "en": "in which the take-up reel rotates about the axis of the rope or cable {or in which a guide member rotates about the axis of the rope or cable to guide the rope or cable on the take-up reel in fixed position} and the supply reels are fixed in position"
