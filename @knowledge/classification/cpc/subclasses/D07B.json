            "ko": null,
            "en": "Ropes or cables with incorporated auxiliary elements, e.g. for marking, extending throughout the length of the rope or cable"
          }
        },
        {
          "code": "D07B 1/16",
          "title": {
            "ko": null,
            "en": "Ropes or cables with an enveloping sheathing or inlays of rubber or plastics (D07B1/04, D07B1/10 take precedence)"
          }
        },
        {
          "code": "D07B 1/18",
          "title": {
            "ko": null,
            "en": "Grommets {(slings B66C1/12)}"
          }
        },
        {
          "code": "D07B 1/20",
